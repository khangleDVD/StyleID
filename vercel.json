{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "functions": {
    "index.py": {
      "maxDuration": 60,
      "excludeFiles": "{app_web_view/**,moble/**,venv/**,.venv/**,uploads/**,artifacts/**,eval_results/**,**/__pycache__/**,*.db,*.sqlite3,.git/**,docs/**,Benchmark Anh AI.xlsx,eval_fashion_accuracy.py}"
    }
  }
}
