# Copy file này thành .env và điền giá trị

FLASK_SECRET_KEY=asdkjfh982374982374!@

# Database — chọn một trong hai:
# • sqlite: chạy local KHÔNG cần XAMPP/MySQL (khuyến nghị dev)
# • mysql: production hoặc khi đã có lumistyle_db trên XAMPP
DB_ENGINE=sqlite
SQLITE_PATH=data/styleid.db

# MySQL (Railway / Vercel) — chỉ khi DB_ENGINE=mysql
# DB_PASSWORD = MYSQL_ROOT_PASSWORD trên Railway (Variables)

# DB_ENGINE=mysql
# DB_HOST=hayabusa.proxy.rlwy.net
# DB_PORT=28031
# DB_USER=root
# DB_PASSWORD=your_railway_password
# DB_NAME=railway

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=your-key-here
# Gợi ý mix (text) — không dùng cho phân tích ảnh
OPENROUTER_MODEL=openai/gpt-4o-mini
# Model riêng cho API dịch giao diện /api/translate (để trống = dùng OPENROUTER_MODEL)
OPENROUTER_TRANSLATE_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT=90

# Phân tích ảnh: đúng 3 model có vision, cách nhau dấu phẩy
OPENROUTER_VISION_MODELS=google/gemini-2.5-flash,anthropic/claude-3-haiku,openai/gpt-5.4-mini

# Cổng lọc ảnh đầu vào — một chủ thể (người mẫu / OOTD / mannequin), không chấp nhận ảnh nhiều người (true/false, mặc định true)
 ENABLE_FASHION_IMAGE_GATE=true
# Model riêng cho bước gate (để trống = model vision đầu tiên ở trên)
 OPENROUTER_GATE_MODEL=google/gemini-2.5-flash
 
# Tối đa món trả về mỗi ảnh (GT benchmark tối đa 10)
# MAX_ITEMS_PER_IMAGE=10
# (Đã loại bỏ) bước hợp nhất kết quả 3 vision hiện thực hiện bằng code thuần — không cần model text.

# Học bổ sung món từ phân tích AI vào data/fashion_style_dataset.json (chỉ khi tên giữ nguyên sau chuẩn hóa fuzzy, chưa có trong danh mục)
# DATASET_LEARN_FROM_ANALYSIS=true


# Tạo OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs — mỗi domain một dòng, khớp 100% (https/http, không / thừa):
#   http://localhost:5000/api/auth/google/callback          (dev local)
#   https://224817-styleid.vercel.app/api/auth/google/callback   (Vercel production)
# Trên Vercel: để trống GOOGLE_REDIRECT_URI — app tự dùng domain hiện tại
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxx
GOOGLE_REDIRECT_URI=
# FRONTEND_URL=   # để trống trên Vercel

# ---------- Payments (chuyển khoản + VietQR + đối soát SePay) ----------
# VietinBank (VietQR bank code) = CTG
NAME_WEB=
PAYMENT_TRANSFER_PREFIX=
SECRET_XOR_KEY=
PAYMENT_EXPIRES_MINUTES=

VIETQR_BANK_CODE=CTG
# VietQR URL ảnh dùng BIN 6 số (acquirer id). Nếu để trống, backend sẽ map CTG -> 970415 (VietinBank).
# VIETQR_ACQUIRER_ID=970415
VIETQR_ACCOUNT_NO=your_account_no
VIETQR_ACCOUNT_NAME=your_account_name
VIETQR_TEMPLATE=compact2

# SePay: endpoint lịch sử + API key (để backend polling/đối soát)
SEPAY_HISTORY_URL=
SEPAY_API_KEY=
SEPAY_TIMEOUT=20

# ---------- Gmail SMTP (OTP đăng ký / quên mật khẩu) ----------
# Bật 2FA Gmail, tạo App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_16_chars
SMTP_FROM=your_gmail@gmail.com
SMTP_FROM_NAME=StyleID
SMTP_USE_TLS=true
SMTP_TIMEOUT=20

